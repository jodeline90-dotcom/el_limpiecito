# ============================================================
# El Limpiecito - Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJ...tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key
SUPABASE_JWT_SECRET=tu_jwt_secret_de_supabase

# --- Base de datos (conexión directa para transacciones) ---
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (emails) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@ellimpiecito.com
EMAIL_FROM_NAME=El Limpiecito

# --- App ---
APP_ENV=development          # development | production
SECRET_KEY=cambia_esto_por_algo_muy_secreto_en_produccion
FRONTEND_URL=http://127.0.0.1:5500
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://ellimpiecito.com

# --- Rate limiting ---
RATE_LIMIT_LOGIN_INTENTOS=5
RATE_LIMIT_LOGIN_VENTANA_MINUTOS=15

# --- Supabase Storage ---
SUPABASE_STORAGE_BUCKET=productos

# --- Railway (producción) ---
PORT=8000
